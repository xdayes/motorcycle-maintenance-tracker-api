{
  "name": "motorcycle-maintenance-tracker-api",
  "version": "1.0.0",
  "description": "REST API for tracking motorcycles, service records, and maintenance reminders.",
  "license": "ISC",
  "author": "Malek Diab",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --env-file=.env --watch src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "render-build": "npm install && npx prisma generate && npx prisma migrate deploy && npm run seed",
    "lint": "eslint ."
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.6.1",
    "prisma": "6.19.0"
  }
}
